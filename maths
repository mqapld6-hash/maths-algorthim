from tkinter import *
from tkinter import messagebox, ttk
import time

# --- THEME COLORS ---
BG_MAIN = "#f4f7f6"
PRIMARY = "#2c3e50"
ACCENT = "#3498db"
SUCCESS = "#27ae60"

class MathApp:
    def __init__(self, root):
        self.root = root
        self.root.title("EquationExplorer | Professional Mathematics Suite")
        self.root.geometry("900x600")
        self.root.configure(bg=BG_MAIN)
        
        # User state
        self.current_user = None
        
        # Start with the login flow
        self.show_login_screen()

    def show_login_screen(self):
        """Creates a custom, polished login window."""
        self.login_window = Toplevel(self.root)
        self.login_window.title("Sign In - EquationExplorer")
        self.login_window.geometry("400x450")
        self.login_window.configure(bg="white")
        self.login_window.transient(self.root)
        self.login_window.grab_set()

        # Logo/Header Area
        header_frame = Frame(self.login_window, bg=PRIMARY, height=100)
        header_frame.pack(fill=X)
        Label(header_frame, text="∑", font=("Arial", 40), bg=PRIMARY, fg="white").pack(pady=(10, 0))
        Label(header_frame, text="Maths Portal", font=("Helvetica", 14), bg=PRIMARY, fg="white").pack(pady=5)

        # Form Area
        form = Frame(self.login_window, bg="white", padx=40, pady=30)
        form.pack(fill=BOTH, expand=True)

        # Email
        Label(form, text="School Email", bg="white", font=("Arial", 9, "bold")).grid(row=0, column=0, sticky=W)
        self.email_ent = Entry(form, font=("Arial", 11), bd=0, highlightthickness=1, highlightbackground="#ddd")
        self.email_ent.grid(row=1, column=0, sticky=EW, pady=(5, 15))
        self.email_ent.insert(0, "student@maths.edu") # Human-like placeholder

        # Password
        Label(form, text="Password", bg="white", font=("Arial", 9, "bold")).grid(row=2, column=0, sticky=W)
        self.pass_ent = Entry(form, font=("Arial", 11), bd=0, highlightthickness=1, highlightbackground="#ddd", show="•")
        self.pass_ent.grid(row=3, column=0, sticky=EW, pady=(5, 20))

        # Login Button
        self.login_btn = Button(form, text="Log In", bg=ACCENT, fg="white", font=("Arial", 11, "bold"), 
                                bd=0, cursor="hand2", command=self.validate_login)
        self.login_btn.grid(row=4, column=0, sticky=EW, ipady=8)

        # Extra Links (The 'fleshed out' details)
        footer = Frame(form, bg="white")
        footer.grid(row=5, column=0, pady=20)
        Label(footer, text="Forgot Password?", fg=ACCENT, bg="white", cursor="hand2").pack(side=LEFT, padx=10)
        Label(footer, text="Register", fg=ACCENT, bg="white", cursor="hand2").pack(side=LEFT, padx=10)

        # Bind Enter key to login
        self.login_window.bind('<Return>', lambda e: self.validate_login())

    def validate_login(self):
        """Real-world style validation logic."""
        email = self.email_ent.get()
        password = self.pass_ent.get()

        if not email or "@" not in email:
            self.email_ent.config(highlightbackground="red")
            messagebox.showerror("Auth Error", "Please provide a valid institutional email.")
            return

        if len(password) < 4:
            messagebox.showwarning("Security", "Password is too short.")
            return

        # Success flow
        self.current_user = email
        self.login_window.destroy()
        self.build_dashboard()

    def build_dashboard(self):
        """The main 'Maths Website' interface after logging in."""
        # Top Navigation Bar
        nav = Frame(self.root, bg=PRIMARY, height=60)
        nav.pack(side=TOP, fill=X)
        
        Label(nav, text=f"Welcome, {self.current_user}", fg="white", bg=PRIMARY, font=("Arial", 10)).pack(side=RIGHT, padx=20)
        Label(nav, text="EquationExplorer v1.2", fg=ACCENT, bg=PRIMARY, font=("Arial", 12, "bold")).pack(side=LEFT, padx=20)

        # Sidebar for Math Tools
        sidebar = Frame(self.root, bg="#ecf0f1", width=200)
        sidebar.pack(side=LEFT, fill=Y)

        tools = ["Arithmetic", "Geometry", "Calculus", "Statistics", "Settings"]
        for tool in tools:
            btn = Button(sidebar, text=tool, font=("Arial", 10), bg="#ecf0f1", bd=0, 
                         anchor="w", padx=20, pady=10, cursor="hand2")
            btn.pack(fill=X)
            # Add a simple hover effect
            btn.bind("<Enter>", lambda e, b=btn: b.config(bg="#dbe2e3"))
            btn.bind("<Leave>", lambda e, b=btn: b.config(bg="#ecf0f1"))

        # Main Workspace area
        self.workspace = Frame(self.root, bg=BG_MAIN, padx=30, pady=30)
        self.workspace.pack(side=RIGHT, fill=BOTH, expand=True)

        self.show_welcome_message()

    def show_welcome_message(self):
        Label(self.workspace, text="Select a module from the sidebar to begin solving.", 
              font=("Helvetica", 14), bg=BG_MAIN, fg="#7f8c8d").pack(expand=True)

# --- EXECUTION ---
if __name__ == "__main__":
    root = Tk()
    # Hidden root until login or splash is ready makes it look smoother
    app = MathApp(root)
    root.mainloop()
