from tkinter import *
from tkinter import messagebox

class MathSiteLogin(Toplevel):
    def __init__(self, parent):
        super().__init__(parent)
        
        self.title("Calculus Academy - Login")
        self.geometry("350x300")
        self.configure(bg="#f0f4f7")  # Soft blue/grey maths theme
        self.resizable(False, False)
        
        self.result = None

        # Main Header
        Label(self, text="Student Portal", font=("Helvetica", 16, "bold"), 
              bg="#f0f4f7", fg="#2c3e50").pack(pady=15)

        # Container for form fields
        form_frame = Frame(self, bg="#f0f4f7")
        form_frame.pack(padx=20)

        # Email Field
        Label(form_frame, text="Email Address:", font=("Arial", 10), bg="#f0f4f7").grid(row=0, column=0, sticky=W, pady=5)
        self.email_entry = Entry(form_frame, width=25)
        self.email_entry.grid(row=0, column=1, pady=5)

        # Password Field
        Label(form_frame, text="Password:", font=("Arial", 10), bg="#f0f4f7").grid(row=1, column=0, sticky=W, pady=5)
        self.pass_entry = Entry(form_frame, width=25, show="*") # Hide password characters
        self.pass_entry.grid(row=1, column=1, pady=5)

        # Button Section
        btn_frame = Frame(self, bg="#f0f4f7")
        btn_frame.pack(pady=20)

        Button(btn_frame, text="Sign In", width=12, bg="#3498db", fg="white", 
               command=self.handle_login).pack(side=LEFT, padx=5)
        
        Button(btn_frame, text="Cancel", width=12, command=self.destroy).pack(side=LEFT, padx=5)

        # Logic Setup
        self.transient(parent)
        self.grab_set()

    def handle_login(self):
        email = self.email_entry.get().strip()
        password = self.pass_entry.get().strip()

        # Basic "Human" Validation
        if "@" not in email or "." not in email:
            messagebox.showwarning("Input Error", "Please enter a valid school email.")
            return

        if len(password) < 6:
            messagebox.showwarning("Security", "Password must be at least 6 characters.")
            return

        # If everything is okay
        self.result = {"email": email, "password": password}
        print(f"Attempting login for: {email}")
        self.destroy()
