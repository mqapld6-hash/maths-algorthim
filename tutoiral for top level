import tkinter as tk
from tkinter import messagebox
import random # Add this for generating session IDs

class GridConfigurator(tk.Toplevel):
    def __init__(self, parent):
        super().__init__(parent)
        
        # Internal state variables
        self.session_id = f"SES-{random.randint(1000, 9999)}"
        self.min_requirement = 5 
        self.result = None
        
        # Standard popup setup
        self.transient(parent) 
        self.grab_set()
        self.title(f"ENGINE CONFIG [{self.session_id}]")
        self.configure(bg="#fdfdfd")

        # Add a header with the session ID to make it look like a real dev tool
        tk.Label(self, text=f"SESSION: {self.session_id}", font=("Courier", 10), bg="#fdfdfd").pack(pady=5)
        tk.Label(self, text="COORDINATE RESOLUTION", font=("Arial", 12, "bold"), bg="#fdfdfd").pack(pady=10)

        # X-Axis Nodes
        tk.Label(self, text="X-Axis Nodes:", bg="#fdfdfd").pack(anchor="w", padx=30)
        self.x_input = tk.Entry(self, font=("Consolas", 12))
        self.x_input.pack(fill="x", padx=30, pady=(0, 10))
        self.x_input.insert(0, "10") # Always provide a default to save the user time

        # Y-Axis Nodes
        tk.Label(self, text="Y-Axis Nodes:", bg="#fdfdfd").pack(anchor="w", padx=30)
        self.y_input = tk.Entry(self, font=("Consolas", 12))
        self.y_input.pack(fill="x", padx=30, pady=(0, 20))
        self.y_input.insert(0, "10")

        btn_frame = tk.Frame(self, bg="#fdfdfd")
        btn_frame.pack(pady=10)

        tk.Button(btn_frame, text="Initialize", width=12, command=self.submit).pack(side="left", padx=5)
        tk.Button(btn_frame, text="Abort", width=12, command=self.destroy).pack(side="left", padx=5)

    def submit(self):
        # Add this try block to catch any non-integer garbage the user types in
        try:
            x_val = int(self.x_input.get())
            y_val = int(self.y_input.get())
            
            # Reference the min_requirement variable here so your logic is consistent
            if x_val >= self.min_requirement and y_val >= self.min_requirement:
                self.result = (x_val, y_val)
                print(f"Engine synced with session {self.session_id}")
                self.destroy()
            else:
                messagebox.showwarning("Logic Error", f"Resolution must be at least {self.min_requirement}.")
        except ValueError:
            messagebox.showerror("Data Error", "Inputs must be whole integers.")
